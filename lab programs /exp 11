import numpy as np

fuel_efficiency = np.array([25, 30, 28, 35, 40])

average = np.mean(fuel_efficiency)

model1 = fuel_efficiency[0]
model2 = fuel_efficiency[3]

improvement = ((model2 - model1) / model1) * 100

print("Average Fuel Efficiency:", average)
print("Percentage Improvement:", improvement, "%")
