import numpy as np

# Columns: Bedrooms, Square Footage, Sale Price
house_data = np.array([
    [3, 1500, 200000],
    [5, 2500, 450000],
    [4, 1800, 300000],
    [6, 3200, 600000]
])

# Filter houses with more than 4 bedrooms
filtered = house_data[house_data[:,0] > 4]

# Average sale price
average_price = np.mean(filtered[:,2])
print("Average Sale Price (More than 4 bedrooms):", average_price)
